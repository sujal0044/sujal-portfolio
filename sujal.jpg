<span class="hljs-comment">/* Glassmorphism utility */</span>
<span class="hljs-selector-class">.glass-card</span> {
  <span class="hljs-keyword">@apply</span> bg-glass backdrop-blur-md border border-white/<span class="hljs-number">10</span> rounded-<span class="hljs-number">2</span>xl transition-all duration-<span class="hljs-number">500</span> <span class="hljs-attribute">hover</span>:border-accent/<span class="hljs-number">50</span> <span class="hljs-attribute">hover</span>:bg-glass-hover;

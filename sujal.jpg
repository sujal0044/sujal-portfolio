                 BUILDING <span class="hljs-tag">&lt;<span class="hljs-name">br</span> /&gt;</span> THE <span class="hljs-tag">&lt;<span class="hljs-name">span</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"text-transparent bg-clip-text bg-gradient-to-r from-[#ff6a00] to-yellow-500"</span>&gt;</span>FUTURE.<span class="hljs-tag">&lt;/<span class="hljs-name">span</span>&gt;</span>

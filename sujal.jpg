    <span class="hljs-tag">&lt;<span class="hljs-name">div</span> <span class="hljs-attr">class</span>=<span class="hljs-string">"px-6 py-3 bg-[#ff6a00] text-black font-bold rounded-full cursor-pointer hover:bg-white transition-colors"</span>&gt;</span>

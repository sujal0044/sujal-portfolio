            <span class="hljs-attr">whileInView</span>=<span class="hljs-string">{{</span> <span class="hljs-attr">opacity:</span> <span class="hljs-attr">1</span>, <span class="hljs-attr">x:</span> <span class="hljs-attr">0</span> }}
            <span class="hljs-attr">viewport</span>=<span class="hljs-string">{{</span> <span class="hljs-attr">once:</span> <span class="hljs-attr">true</span> }}
            <span class="hljs-attr">className</span>=<span class="hljs-string">"glass-card p-10"</span>
          &gt;</span>
            <span class="hljs-tag">&lt;<span class="hljs-name">h3</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"text-2xl font-bold mb-6 text-white"</span>&gt;</span>Philosophy &amp; Personality<span class="hljs-tag">&lt;/<span class="hljs-name">h3</span>&gt;</span>
            <span class="hljs-tag">&lt;<span class="hljs-name">p</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"text-gray-400 mb-4 leading-relaxed"</span>&gt;</span>
              I am an ambitious international student whose journey bridges a Bachelor's in India to pursuing a Master of Computer Science at the University of East London. 
            <span class="hljs-tag">&lt;/<span class="hljs-name">p</span>&gt;</span>
            <span class="hljs-tag">&lt;<span class="hljs-name">p</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"text-gray-400 mb-4 leading-relaxed"</span>&gt;</span>
              Beyond the IDE, I am a disciplined learner and avid reader of psychology and self-growth literature. This perspective ensures I remain exceptionally calm under pressure, adapting swiftly to harsh situations and complex problem-solving requirements.
            <span class="hljs-tag">&lt;/<span class="hljs-name">p</span>&gt;</span>
          <span class="hljs-tag">&lt;/<span class="hljs-name">motion.div</span>&gt;</span>

          <span class="hljs-tag">&lt;<span class="hljs-name">motion.div</span> 
            <span class="hljs-attr">initial</span>=<span class="hljs-string">{{</span> <span class="hljs-attr">opacity:</span> <span class="hljs-attr">0</span>, <span class="hljs-attr">x:</span> <span class="hljs-attr">50</span> }}
            <span class="hljs-attr">whileInView</span>=<span class="hljs-string">{{</span> <span class="hljs-attr">opacity:</span> <span class="hljs-attr">1</span>, <span class="hljs-attr">x:</span> <span class="hljs-attr">0</span> }}
            <span class="hljs-attr">viewport</span>=<span class="hljs-string">{{</span> <span class="hljs-attr">once:</span> <span class="hljs-attr">true</span> }}
            <span class="hljs-attr">className</span>=<span class="hljs-string">"glass-card p-10 flex flex-col justify-center border-accent/20"</span>
          &gt;</span>
             <span class="hljs-tag">&lt;<span class="hljs-name">h3</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"text-2xl font-bold mb-6 text-accent"</span>&gt;</span>Academic Journey<span class="hljs-tag">&lt;/<span class="hljs-name">h3</span>&gt;</span>
             <span class="hljs-tag">&lt;<span class="hljs-name">ul</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"space-y-6"</span>&gt;</span>
               <span class="hljs-tag">&lt;<span class="hljs-name">li</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"relative pl-6 border-l border-white/20"</span>&gt;</span>
                 <span class="hljs-tag">&lt;<span class="hljs-name">span</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"absolute left-[-5px] top-2 w-2 h-2 rounded-full bg-accent"</span>&gt;</span><span class="hljs-tag">&lt;/<span class="hljs-name">span</span>&gt;</span>
                 <span class="hljs-tag">&lt;<span class="hljs-name">h4</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"text-white font-bold"</span>&gt;</span>Master of Computer Science<span class="hljs-tag">&lt;/<span class="hljs-name">h4</span>&gt;</span>
                 <span class="hljs-tag">&lt;<span class="hljs-name">p</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"text-gray-500 text-sm"</span>&gt;</span>University of East London, UK (Jan 2026 – Present)<span class="hljs-tag">&lt;/<span class="hljs-name">p</span>&gt;</span>
               <span class="hljs-tag">&lt;/<span class="hljs-name">li</span>&gt;</span>
               <span class="hljs-tag">&lt;<span class="hljs-name">li</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"relative pl-6 border-l border-white/20"</span>&gt;</span>
                 <span class="hljs-tag">&lt;<span class="hljs-name">span</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"absolute left-[-5px] top-2 w-2 h-2 rounded-full bg-white/50"</span>&gt;</span><span class="hljs-tag">&lt;/<span class="hljs-name">span</span>&gt;</span>
                 <span class="hljs-tag">&lt;<span class="hljs-name">h4</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"text-white font-bold"</span>&gt;</span>Bachelor of CS &amp; IT<span class="hljs-tag">&lt;/<span class="hljs-name">h4</span>&gt;</span>
                 <span class="hljs-tag">&lt;<span class="hljs-name">p</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"text-gray-500 text-sm"</span>&gt;</span>India<span class="hljs-tag">&lt;/<span class="hljs-name">p</span>&gt;</span>
               <span class="hljs-tag">&lt;/<span class="hljs-name">li</span>&gt;</span>
             <span class="hljs-tag">&lt;/<span class="hljs-name">ul</span>&gt;</span>
          <span class="hljs-tag">&lt;/<span class="hljs-name">motion.div</span>&gt;</span>
        <span class="hljs-tag">&lt;/<span class="hljs-name">div</span>&gt;</span>
      <span class="hljs-tag">&lt;/<span class="hljs-name">div</span>&gt;</span>
    <span class="hljs-tag">&lt;/<span class="hljs-name">section</span>&gt;</span></span>
  );
};

<span class="hljs-keyword">export</span> <span class="hljs-keyword">default</span> About;
</code></pre><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><hr data-path-to-node="25"><h3 data-path-to-node="26">Deployment &amp; Production Preparation</h3><p data-path-to-node="27"><b data-path-to-node="27" data-index-in-node="0">1. Optimization for Vercel/Netlify:</b></p><ul data-path-to-node="28"><li><p data-path-to-node="28,0,0">Ensure images (<code data-path-to-node="28,0,0" data-index-in-node="15">sujal-portrait.jpg</code>) are converted to <code data-path-to-node="28,0,0" data-index-in-node="52">WebP</code> format for extremely fast loading times.</p></li><li><p data-path-to-node="28,1,0">Add <code data-path-to-node="28,1,0" data-index-in-node="4">&lt;meta name="theme-color" content="#050505" /&gt;</code> to your <code data-path-to-node="28,1,0" data-index-in-node="58">index.html</code> to make mobile browser tabs match the cinematic dark mode.</p></li></ul><p data-path-to-node="29"><b data-path-to-node="29" data-index-in-node="0">2. Achieving 60FPS Animations:</b></p><ul data-path-to-node="30"><li><p data-path-to-node="30,0,0"><code data-path-to-node="30,0,0" data-index-in-node="0">Framer Motion</code> handles hardware acceleration automatically for transforms (<code data-path-to-node="30,0,0" data-index-in-node="74">x</code>, <code data-path-to-node="30,0,0" data-index-in-node="77">y</code>, <code data-path-to-node="30,0,0" data-index-in-node="80">scale</code>) and <code data-path-to-node="30,0,0" data-index-in-node="91">opacity</code>. Avoid animating layout properties like <code data-path-to-node="30,0,0" data-index-in-node="139">width</code>, <code data-path-to-node="30,0,0" data-index-in-node="146">height</code>, or <code data-path-to-node="30,0,0" data-index-in-node="157">margin</code> on scroll.</p></li><li><p data-path-to-node="30,1,0">The <code data-path-to-node="30,1,0" data-index-in-node="4">ReactLenis</code> wrapper intercepts native scrolling to provide the "smooth, heavy" luxury feel requested, completely overriding the jarring default browser scroll.</p></li></ul><p data-path-to-node="31"><b data-path-to-node="31" data-index-in-node="0">3. Deployment Command:</b>
To deploy, push your repository to GitHub, link it to Vercel or Netlify, and ensure the build command is <code data-path-to-node="31" data-index-in-node="128">npm run build</code> and the output directory is <code data-path-to-node="31" data-index-in-node="170">dist</code>.</p></div></message-content><!----></div></structured-content-container><!----><!----><!----><div _ngcontent-ng-c3655342764="" class="response-footer complete has-thoughts gap"><!----><!----><!----><sources-list _ngcontent-ng-c3655342764="" class="sources-list ng-star-inserted" style=""><!----></sources-list><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></div></div><!----><sensitive-memories-banner _ngcontent-ng-c3655342764="" _nghost-ng-c1490227791="" class="ng-star-inserted"><!----></sensitive-memories-banner><!----><!----><!----></div></div><div _ngcontent-ng-c1865031762="" class="response-container-footer ng-tns-c1865031762-15 ng-star-inserted"><!----><!----><!----><message-actions _ngcontent-ng-c3655342764="" footer="" _nghost-ng-c429900870="" class="ng-tns-c429900870-16 hide-action-bar ng-tns-c1865031762-15 ng-star-inserted"><div _ngcontent-ng-c429900870="" class="actions-container-v2 ng-tns-c429900870-16"><div _ngcontent-ng-c429900870="" class="buttons-container-v2 ng-tns-c429900870-16 ng-star-inserted"><!----><thumb-up-button _ngcontent-ng-c429900870="" _nghost-ng-c2375852602="" class="ng-tns-c429900870-16 ng-star-inserted"><!----><button _ngcontent-ng-c2375852602="" mat-icon-button="" mattooltip="Good response" aria-label="Good response" data-test-id="thumb-up-button" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger icon-button mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" aria-pressed="false" jslog="173913;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_1b948449121c1645&quot;,&quo